generator client {
  provider = "prisma-client"
  output   = "../src/server/db/generated"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum EstadoClinica {
  ACTIVA
  SUSPENDIDA
  PRUEBA
}

enum Rol {
  ADMINISTRADOR
  ODONTOLOGO
  RECEPCION
  CAJA
}

enum TipoDocumentoResponsable {
  DUI
  PASAPORTE
  CARNET_RESIDENTE
}

// La Agenda solo distingue una cita vigente de una cancelada. NO_ASISTIO queda
// fuera hasta que Carlos decida si debe liberar el horario (pendiente #1).
enum EstadoCita {
  PENDIENTE
  CANCELADA
}

enum Denticion {
  PERMANENTE
  TEMPORAL
}

enum TipoDiente {
  INCISIVO
  CANINO
  PREMOLAR
  MOLAR
}

enum Superficie {
  COMPLETO
  MESIAL
  DISTAL
  VESTIBULAR
  PALATINA
  LINGUAL
  INCISAL
  OCLUSAL
}

// BOCA cubre tratamientos que no se anclan a una pieza (limpieza, consulta,
// ortodoncia). DIENTE exige o admite piezas según las banderas del tratamiento.
enum AlcanceTratamiento {
  DIENTE
  BOCA
}

model Clinica {
  id            String        @id @default(cuid())
  nombre        String
  estado        EstadoClinica @default(PRUEBA)
  vigenteHasta  DateTime?     @map("vigente_hasta") @db.Timestamptz(3)
  creadoEn      DateTime      @default(now()) @map("creado_en") @db.Timestamptz(3)
  actualizadoEn DateTime      @updatedAt @map("actualizado_en") @db.Timestamptz(3)

  sucursales Sucursal[]
  membresias Membresia[]
  auditorias Auditoria[]
  pacientes  Paciente[]
  citas      Cita[]      @relation("CitaClinica")
  expedientes                     Expediente[]
  alertasMedicas                  AlertaMedica[]
  desactivacionesAlertasMedicas   DesactivacionAlertaMedica[]
  categoriasTratamiento           CategoriaTratamiento[]
  tratamientos                    Tratamiento[]

  @@map("clinicas")
}

model Sucursal {
  id            String   @id @default(cuid())
  clinicaId     String   @map("clinica_id")
  nombre        String
  creadoEn      DateTime @default(now()) @map("creado_en") @db.Timestamptz(3)
  actualizadoEn DateTime @updatedAt @map("actualizado_en") @db.Timestamptz(3)

  clinica Clinica @relation(fields: [clinicaId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  citas   Cita[]  @relation("CitaSucursal")

  @@unique([clinicaId, id])
  @@index([clinicaId])
  @@map("sucursales")
}

model Usuario {
  id                      String    @id @default(cuid())
  correo                  String    @unique
  nombre                  String
  passwordHash            String?   @map("password_hash")
  tokenInvitacionHash     String?   @unique @map("token_invitacion_hash")
  tokenInvitacionExpiraEn DateTime? @map("token_invitacion_expira_en") @db.Timestamptz(3)
  esOperadorPlataforma    Boolean   @default(false) @map("es_operador_plataforma")
  creadoEn                DateTime  @default(now()) @map("creado_en") @db.Timestamptz(3)
  actualizadoEn           DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz(3)

  membresias Membresia[]
  auditorias Auditoria[]

  @@map("usuarios")
}

model Membresia {
  id            String   @id @default(cuid())
  clinicaId     String   @map("clinica_id")
  usuarioId     String   @map("usuario_id")
  roles         Rol[]
  activa        Boolean  @default(true)
  jvpo          String?
  especialidad  String?
  colorAgenda   String?  @map("color_agenda")
  creadoEn      DateTime @default(now()) @map("creado_en") @db.Timestamptz(3)
  actualizadoEn DateTime @updatedAt @map("actualizado_en") @db.Timestamptz(3)

  clinica Clinica @relation(fields: [clinicaId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  citasComoOdontologo          Cita[]                       @relation("CitaOdontologo")
  alertasCreadas               AlertaMedica[]               @relation("AlertaCreadaPor")
  desactivacionesAlertasMedicas DesactivacionAlertaMedica[] @relation("AlertaDesactivadaPor")

  @@unique([usuarioId, clinicaId])
  @@unique([clinicaId, id])
  @@index([clinicaId])
  @@index([usuarioId])
  @@map("membresias")
}

model Auditoria {
  id        String   @id @default(cuid())
  clinicaId String   @map("clinica_id")
  usuarioId String?  @map("usuario_id")
  accion    String
  entidad   String
  entidadId String?  @map("entidad_id")
  detalle   Json?
  creadoEn  DateTime @default(now()) @map("creado_en") @db.Timestamptz(3)

  clinica Clinica  @relation(fields: [clinicaId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([clinicaId, id])
  @@index([clinicaId])
  @@index([usuarioId])
  @@map("auditoria")
}

model Paciente {
  id                          String                    @id @default(cuid())
  clinicaId                   String                    @map("clinica_id")
  nombres                     String
  apellidos                   String
  fechaNacimiento             DateTime                  @map("fecha_nacimiento") @db.Date
  dui                         String?
  duiEnmascarado              String?                   @default(dbgenerated()) @map("dui_enmascarado")
  telefono                    String
  correo                      String?
  direccion                   String?
  responsableNombre           String?                   @map("responsable_nombre")
  responsableTipoDocumento    TipoDocumentoResponsable? @map("responsable_tipo_documento")
  responsableNumDocumento     String?                   @map("responsable_num_documento")
  responsableTelefono         String?                   @map("responsable_telefono")
  responsableParentesco       String?                   @map("responsable_parentesco")
  contactoEmergenciaNombre    String                    @map("contacto_emergencia_nombre")
  contactoEmergenciaTelefono  String                    @map("contacto_emergencia_telefono")
  creadoEn                    DateTime                  @default(now()) @map("creado_en") @db.Timestamptz(3)
  actualizadoEn               DateTime                  @updatedAt @map("actualizado_en") @db.Timestamptz(3)

  clinica Clinica @relation(fields: [clinicaId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  citas   Cita[]  @relation("CitaPaciente")
  expediente Expediente?

  @@unique([clinicaId, id])
  @@unique([clinicaId, dui])
  @@index([clinicaId, apellidos, nombres])
  @@index([clinicaId, telefono])
  @@map("pacientes")
}

// El expediente es el contenedor clínico 1:1 del paciente. Se crea en la misma
// transacción que el paciente; la relación inversa queda opcional porque PostgreSQL
// no puede exigir la existencia del hijo sin un trigger, que CLIDENT no utiliza.
model Expediente {
  id            String   @id @default(cuid())
  clinicaId     String   @map("clinica_id")
  pacienteId    String   @map("paciente_id")
  creadoEn      DateTime @default(now()) @map("creado_en") @db.Timestamptz(3)
  actualizadoEn DateTime @updatedAt @map("actualizado_en") @db.Timestamptz(3)

  clinica  Clinica  @relation(fields: [clinicaId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  paciente Paciente @relation(fields: [clinicaId, pacienteId], references: [clinicaId, id], onDelete: Restrict, onUpdate: Restrict)
  alertas  AlertaMedica[]

  @@unique([clinicaId, id])
  @@unique([clinicaId, pacienteId])
  @@map("expedientes")
}

// Una alerta registra una advertencia clínica visible solo a personal clínico.
// Es append-only: su desactivación es otro registro inmutable, no un UPDATE.
model AlertaMedica {
  id              String   @id @default(cuid())
  clinicaId       String   @map("clinica_id")
  expedienteId    String   @map("expediente_id")
  titulo          String
  detalle         String?
  creadaPorId     String   @map("creada_por_id")
  creadoEn        DateTime @default(now()) @map("creado_en") @db.Timestamptz(3)

  clinica       Clinica                     @relation(fields: [clinicaId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  expediente    Expediente                  @relation(fields: [clinicaId, expedienteId], references: [clinicaId, id], onDelete: Restrict, onUpdate: Restrict)
  creadaPor     Membresia                   @relation("AlertaCreadaPor", fields: [clinicaId, creadaPorId], references: [clinicaId, id], onDelete: Restrict, onUpdate: Restrict)
  desactivacion DesactivacionAlertaMedica?

  @@unique([clinicaId, id])
  @@index([clinicaId, expedienteId])
  @@map("alertas_medicas")
}

// Cerrar una alerta es un hecho clínico trazable. Solo puede existir un cierre por
// alerta; para volver a advertir algo se crea una alerta nueva, sin reescribir historia.
model DesactivacionAlertaMedica {
  id                  String   @id @default(cuid())
  clinicaId           String   @map("clinica_id")
  alertaId            String   @map("alerta_id")
  desactivadaPorId    String   @map("desactivada_por_id")
  motivoDesactivacion String   @map("motivo_desactivacion")
  desactivadaEn       DateTime @default(now()) @map("desactivada_en") @db.Timestamptz(3)

  clinica          Clinica       @relation(fields: [clinicaId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  alerta           AlertaMedica  @relation(fields: [clinicaId, alertaId], references: [clinicaId, id], onDelete: Restrict, onUpdate: Restrict)
  desactivadaPor   Membresia     @relation("AlertaDesactivadaPor", fields: [clinicaId, desactivadaPorId], references: [clinicaId, id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([clinicaId, id])
  @@unique([clinicaId, alertaId])
  @@map("desactivaciones_alertas_medicas")
}

model Cita {
  id                   String     @id @default(cuid())
  clinicaId            String     @map("clinica_id")
  sucursalId           String     @map("sucursal_id")
  pacienteId           String     @map("paciente_id")
  odontologoId         String     @map("odontologo_id")
  inicioEn             DateTime   @map("inicio_en") @db.Timestamptz(3)
  finEn                DateTime   @map("fin_en") @db.Timestamptz(3)
  estado               EstadoCita @default(PENDIENTE)
  motivo               String?
  notasAdministrativas String?    @map("notas_administrativas")
  creadoEn             DateTime   @default(now()) @map("creado_en") @db.Timestamptz(3)
  actualizadoEn        DateTime   @updatedAt @map("actualizado_en") @db.Timestamptz(3)

  clinica    Clinica    @relation("CitaClinica", fields: [clinicaId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  sucursal   Sucursal   @relation("CitaSucursal", fields: [clinicaId, sucursalId], references: [clinicaId, id], onDelete: Restrict, onUpdate: Restrict)
  paciente   Paciente   @relation("CitaPaciente", fields: [clinicaId, pacienteId], references: [clinicaId, id], onDelete: Restrict, onUpdate: Restrict)
  odontologo Membresia @relation("CitaOdontologo", fields: [clinicaId, odontologoId], references: [clinicaId, id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([clinicaId, id])
  @@index([clinicaId, inicioEn])
  @@index([clinicaId, pacienteId])
  @@index([clinicaId, odontologoId])
  @@map("citas")
}

// Plantillas de plataforma (REFERENCIA_GLOBAL): se COPIAN al catálogo de cada
// clínica con clonarCatalogo(). La app solo las lee; las siembra el migrador.
model PlantillaCategoria {
  id     String @id
  nombre String
  orden  Int    @unique

  plantillas PlantillaTratamiento[]

  @@map("plantillas_categoria")
}

model PlantillaTratamiento {
  codigo                      String             @id
  categoriaId                 String             @map("categoria_id")
  nombre                      String
  precioSugeridoCentavos      Int                @map("precio_sugerido_centavos")
  alcance                     AlcanceTratamiento
  requiereDiente              Boolean            @map("requiere_diente")
  permiteMultiplesDientes     Boolean            @map("permite_multiples_dientes")
  permiteSuperficies          Boolean            @map("permite_superficies")
  permiteMultiplesSuperficies Boolean            @map("permite_multiples_superficies")
  requiereDiagnostico         Boolean            @map("requiere_diagnostico")
  permiteMultiplesSesiones    Boolean            @map("permite_multiples_sesiones")

  categoria PlantillaCategoria @relation(fields: [categoriaId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@map("plantillas_tratamiento")
}

model CategoriaTratamiento {
  id            String   @id @default(cuid())
  clinicaId     String   @map("clinica_id")
  nombre        String
  orden         Int
  creadoEn      DateTime @default(now()) @map("creado_en") @db.Timestamptz(3)
  actualizadoEn DateTime @updatedAt @map("actualizado_en") @db.Timestamptz(3)

  clinica      Clinica       @relation(fields: [clinicaId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  tratamientos Tratamiento[]

  @@unique([clinicaId, id])
  @@unique([clinicaId, nombre])
  @@index([clinicaId])
  @@map("categorias_tratamiento")
}

// El catálogo maestro de la clínica. Sin columna de superficie a propósito
// (REGLAS-DE-NEGOCIO §4.7): las superficies existen solo al asignar el
// tratamiento a un paciente. El precio de un plan NUNCA se lee de aquí (ADR-006).
model Tratamiento {
  id                          String             @id @default(cuid())
  clinicaId                   String             @map("clinica_id")
  categoriaId                 String             @map("categoria_id")
  codigo                      String
  nombre                      String
  precioListaCentavos         Int                @map("precio_lista_centavos")
  activo                      Boolean            @default(true)
  alcance                     AlcanceTratamiento
  requiereDiente              Boolean            @map("requiere_diente")
  permiteMultiplesDientes     Boolean            @map("permite_multiples_dientes")
  permiteSuperficies          Boolean            @map("permite_superficies")
  permiteMultiplesSuperficies Boolean            @map("permite_multiples_superficies")
  requiereDiagnostico         Boolean            @map("requiere_diagnostico")
  permiteMultiplesSesiones    Boolean            @map("permite_multiples_sesiones")
  creadoEn                    DateTime           @default(now()) @map("creado_en") @db.Timestamptz(3)
  actualizadoEn               DateTime           @updatedAt @map("actualizado_en") @db.Timestamptz(3)

  clinica   Clinica              @relation(fields: [clinicaId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  categoria CategoriaTratamiento @relation(fields: [clinicaId, categoriaId], references: [clinicaId, id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([clinicaId, id])
  @@unique([clinicaId, codigo])
  @@index([clinicaId, categoriaId])
  @@map("tratamientos")
}

model DienteRef {
  fdi       Int        @id
  denticion Denticion
  tipo      TipoDiente
  cuadrante Int
  posicion  Int
  nombre    String

  superficies SuperficieDiente[]

  @@map("dientes_ref")
}

model SuperficieDiente {
  fdi        Int
  superficie Superficie

  diente DienteRef @relation(fields: [fdi], references: [fdi], onDelete: Restrict, onUpdate: Restrict)

  @@id([fdi, superficie])
  @@map("superficies_diente")
}
