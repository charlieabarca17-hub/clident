# Runtime local: solo el rol de aplicación, siempre con pooler.
DATABASE_URL="postgresql://clident_app:CAMBIAR@HOST/neondb?sslmode=require&pgbouncer=true"
AUTH_SECRET="CAMBIAR_POR_32_O_MAS_CARACTERES_ALEATORIOS"

# Integración opcional por usuario con un calendario secundario de Google.
GOOGLE_CLIENT_ID="CLIENTE_WEB_DE_GOOGLE.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="CAMBIAR_EN_VERCEL"
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/api/integraciones/google-calendar/callback"
# 32 bytes aleatorios codificados en base64. Ej.: openssl rand -base64 32
GOOGLE_TOKEN_ENCRYPTION_KEY="CAMBIAR_POR_32_BYTES_EN_BASE64"

# Nunca se carga en Next.js ni en Vercel. Se inyecta solo en CI/CD para migraciones.
# MIGRATION_DATABASE_URL="postgresql://clident_migrator:CAMBIAR@HOST/neondb?sslmode=require"

# Guarda explícita para permitir el TRUNCATE del arnés de integración únicamente en pruebas.
# TEST_DATABASE_CONFIRM=pruebas
