# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NUNCA se commitean. DATABASE_URL vive localmente y luego en Vercel;
# MIGRATION_DATABASE_URL solo existe en GitHub Actions, nunca en runtime ni en local
# (ADR-010, ARQUITECTURA.md §4.4).
.env*
!.env.example

# Prisma 7 genera un cliente tipado localmente desde prisma/schema.prisma.
# El cliente se regenera con `npm run prisma:generate`; no es fuente autoritativa.
/src/server/db/generated/

# vercel
.vercel

# herramientas locales del desarrollador — no son del proyecto
.neon
.claude/
.agents/
skills-lock.json

# typescript
*.tsbuildinfo
next-env.d.ts
